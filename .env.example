# .env.example — copy to .env and fill in real values before running.
#
# All variables are prefixed with OMR_.
# The app reads this file automatically if it is placed in the project root.
# In Docker, prefer passing variables via -e or --env-file.

# ── Authentication ────────────────────────────────────────────────────────────
# Secret key required in the X-API-Key header for all protected endpoints.
# Leave EMPTY to run in open dev mode (a WARNING will be logged).
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"
OMR_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
# Absolute or relative path where per-run result directories are created.
# In Docker, bind-mount a volume here so results survive container restarts.
OMR_RUNS_DIR=web_runs

# ── Upload limits ─────────────────────────────────────────────────────────────
# Maximum upload size in megabytes. Uploads larger than this return 413.
OMR_MAX_UPLOAD_MB=25

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Maximum number of /scan requests per IP address per minute. Excess returns 429.
OMR_RATE_LIMIT_PER_MINUTE=30

# ── Concurrency ───────────────────────────────────────────────────────────────
# Maximum simultaneous OMR pipeline runs per worker process.
# Set to match available CPU threads (recommend 1-2 per core for CPU-bound work).
OMR_MAX_CONCURRENT_JOBS=2

# Seconds a request waits for a free job slot before returning 503.
OMR_QUEUE_WAIT_S=10.0

# ── Run lifecycle (disk cleanup) ──────────────────────────────────────────────
# Run directories older than this many hours are deleted by the background sweeper.
OMR_RUN_TTL_HOURS=24.0

# How often the sweeper checks for stale runs (seconds).
OMR_SWEEPER_INTERVAL_S=300.0

# ── Debug artifacts ───────────────────────────────────────────────────────────
# 1 (default): write intermediate debug JPEGs per run so the result page shows
# processing steps (original, warped, grid, classified, answered).
# Set to 0 in production to save ~4 MB/run (only result_v3.json is kept).
OMR_DEBUG_ARTIFACTS=1

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level for the application. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
OMR_LOG_LEVEL=INFO
